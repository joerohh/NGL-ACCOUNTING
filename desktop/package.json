{
  "name": "ngl-accounting",
  "version": "2.12.0",
  "description": "NGL Accounting Service — Invoice management and document automation",
  "main": "main.js",
  "scripts": {
    "start": "node dev-launch.js",
    "dev": "node dev-launch.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "NGL Trans",
  "license": "UNLICENSED",
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.ngltrans.accounting",
    "productName": "NGL Accounting",
    "copyright": "Copyright (C) 2026 NGL Trans",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NGL Accounting",
      "artifactName": "NGL_ACCOUNTING_INSTALLER_v${version}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "../app",
        "to": "webapp",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      },
      {
        "from": "./agent-dist",
        "to": "agent",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "joerohh",
        "repo": "NGL-ACCOUNTING",
        "private": true,
        "releaseType": "release"
      }
    ],
    "forceCodeSigning": false
  }
}
