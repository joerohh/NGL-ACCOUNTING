{
  "_comment": "QBO DOM selectors — update these if QuickBooks changes their UI",
  "login": {
    "email_input": "input#ius-userid",
    "password_input": "input#ius-password",
    "sign_in_button": "button[data-testid='ius-sign-in-submit-btn']",
    "logged_in_indicator": "[data-testid='qbo-nav'], .qbo-nav, #globalNavigation"
  },
  "search": {
    "global_search_input": "input[placeholder*='search' i], input[placeholder*='navigate' i], input[data-testid='global-search-input'], #search-input",
    "search_result_item": "[data-testid='search-result-item'], .search-result-row, .gns-result-row, [class*='SearchResult'], [role='option']",
    "invoice_link": "a[href*='invoice'], a[href*='txnId']"
  },
  "invoice": {
    "pdf_download_button": "button[data-testid='download-pdf'], [aria-label*='PDF'], [aria-label*='Download'], button:has-text('PDF')",
    "more_actions_button": "button[data-testid='more-actions'], button:has-text('More')",
    "print_or_download": "[data-testid='print-action'], [data-testid='download-action']",
    "attachments_section": "[data-testid='attachments'], .attachments-section, .txn-attachments",
    "attachment_item": "[data-testid='attachment-item'], .attachment-row, .attachment-thumbnail",
    "attachment_name": "[data-testid='attachment-name'], .attachment-name, .attachment-filename",
    "attachment_download": "[data-testid='attachment-download'], a[download], .attachment-download-link"
  }
}
