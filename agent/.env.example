# =============================================
#  NGL Agent — Environment Variables
# =============================================
#  Copy this file to ".env" and fill in your values.
#  NEVER commit the real .env file!
#
#  On a new device:  copy .env.example .env
#  Then edit .env with your actual keys/passwords.
# =============================================

# Anthropic API key for Claude Haiku classification
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Local agent auth token (keep same across devices)
NGL_AGENT_TOKEN=ngl-local-dev-token

# Gmail SMTP for POD emails (OEC flow)
# Get an App Password: Google Account > Security > 2-Step Verification > App passwords
GMAIL_ADDRESS=your.email@ngltrans.net
GMAIL_APP_PASSWORD=your_app_password_here

# TranzAct portal credentials (TrueVal flow)
TRANZACT_USERNAME=your.email@ngltrans.net
TRANZACT_PASSWORD=your_password_here
